<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Operator Admin Antrian</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 0; }
        body { background-color: #f4f6f9; color: #333; padding: 20px; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 900px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        @media (max-width: 768px) { .container { grid-template-columns: 1fr; } }
        .card { background: #fff; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        h2 { color: #2c3e50; font-size: 1.4rem; border-bottom: 2px solid #edf2f7; padding-bottom: 10px; margin-bottom: 15px;}
        button { width: 100%; padding: 14px; border: none; border-radius: 6px; font-size: 1rem; font-weight: bold; cursor: pointer; }
        .btn-success { background-color: #10b981; color: white; margin-bottom: 10px; }
        .btn-success:hover { background-color: #059669; }
        .display-antrian { text-align: center; background: #f8fafc; border: 2px dashed #cbd5e1; border-radius: 8px; padding: 25px; margin-bottom: 15px; }
        .nomor-besar { font-size: 4.5rem; font-weight: 800; color: #3b82f6; margin: 10px 0; }
        .list-wrapper { max-height: 400px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 6px; }
        table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #e2e8f0; }
        th { background-color: #f1f5f9; position: sticky; top: 0; }
    </style>
</head>
<body>

<div class="container">
    <div class="card">
        <h2>Kontrol Panggilan Antrian</h2>
        <div class="display-antrian">
            <p>Antrian Sekarang yang Dipanggil:</p>
            <div class="nomor-besar" id="nomorDipanggil">0</div>
            <p style="font-weight: bold;" id="detailDipanggil">-</p>
        </div>
        <button class="btn-success" id="btnPanggil">Panggil Antrian Berikutnya</button>
    </div>

    <div class="card">
        <h2>Pendaftar Masuk Hari Ini Real-Time</h2>
        <div style="margin-bottom: 10px; font-weight: bold; color: #475569;">
            Total Terdaftar: <span id="totalPendaftar">0</span> / 150
        </div>
        <div class="list-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Nama</th>
                        <th>Jurusan</th>
                    </tr>
                </thead>
                <tbody id="tabelAntrian"></tbody>
            </table>
        </div>
    </div>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
    import { getDatabase, ref, onValue, set } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js";

    const firebaseConfig = { databaseURL: "https://antrian-spmb-default-rtdb.firebaseio.com/" };
    const app = initializeApp(firebaseConfig);
    const db = getDatabase(app);

    const hariIni = new Date();
    const tanggalKey = `${hariIni.getFullYear()}-${hariIni.getMonth() + 1}-${hariIni.getDate()}`;
    
    let listSiswa = [];
    let noSekarang = 0;

    // 1. Dengarkan database (Setiap ada siswa daftar di HP, langsung otomatis masuk tabel ini tanpa di-refresh)
    onValue(ref(db, `antrian/${tanggalKey}`), (snapshot) => {
        const data = snapshot.val();
        const tbody = document.getElementById('tabelAntrian');
        tbody.innerHTML = '';
        listSiswa = [];

        if (data) {
            Object.keys(data).forEach((key) => {
                const siswa = data[key];
                listSiswa.push(siswa);
                const row = `<tr><td><b>${siswa.nomor}</b></td><td>${siswa.nama}</td><td>${siswa.jurusan}</td></tr>`;
                tbody.innerHTML += row;
            });
        }
        document.getElementById('totalPendaftar').innerText = listSiswa.length;
    });

    // 2. Dengarkan Status Nomor yang sedang dipanggil
    onValue(ref(db, `panggilan/${tanggalKey}`), (snapshot) => {
        const data = snapshot.val();
        if (data) {
            noSekarang = data.nomor;
            document.getElementById('nomorDipanggil').innerText = data.nomor;
            document.getElementById('detailDipanggil').innerText = `${data.nama} (${data.jurusan})`;
        }
    });

    // 3. Tombol Eksekusi Panggilan suara & ganti nomor
    document.getElementById('btnPanggil').addEventListener('click', () => {
        let nomorTarget = noSekarang + 1;
        let siswaTarget = listSiswa.find(s => s.nomor === nomorTarget);

        if (siswaTarget) {
            // Update nomor panggil ke Firebase agar sinkron
            set(ref(db, `panggilan/${tanggalKey}`), siswaTarget);

            // Suara Robot Panggilan
            if ('speechSynthesis' in window) {
                const ucapan = new SpeechSynthesisUtterance(`Nomor antrian ${siswaTarget.nomor}, atas nama ${siswaTarget.nama}, silahkan menuju loket`);
                ucapan.lang = 'id-ID';
                window.speechSynthesis.speak(ucapan);
            }
        } else {
            alert("Tidak ada antrian berikutnya atau siswa belum mendaftar.");
        }
    });
</script>
</body>
</html>
